              "concepts/sources",
              "concepts/source-sets-and-dependencies",
              "concepts/define-and-resolve",
              "concepts/policies-and-budget",
              "concepts/chunks-and-strategies",
              "concepts/budget-strategy-playground",
              "concepts/templates-and-token-measurement",
              "concepts/trace-and-observability"
            ]
          },
          {
            "group": "Practical guides",
            "pages": [
              "guides/support-reply-walkthrough",
              "guides/common-failure-modes"
            ]
          }
        ]
      },
      {
        "tab": "Reference",
        "groups": [
          {
            "group": "API",
            "pages": [
              "reference/api-overview",
              "reference/create-polo",
              "reference/source-factory",
              "reference/source-set-and-register-sources",
